{
  "permissions": {
    "allow": [
      "Bash(uv run python build.py)",
      "Bash(uv run pytest)",
      "Bash(uv run pytest *)",
      "Bash(date > .claude/last-review.txt)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
